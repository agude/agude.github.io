# Dockerfile.prettier
#
# Lightweight Node image for running Prettier on Markdown files.
# No package.json needed — Prettier is installed globally.

FROM node:22-alpine

# Pin the Prettier version for reproducible builds.
ARG PRETTIER_VERSION=3.8.1
RUN npm install -g prettier@${PRETTIER_VERSION} && npm cache clean --force

WORKDIR /workspace

# No CMD needed — provided by docker run
